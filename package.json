{
    "name": "react-layman",
    "version": "0.3.0",
    "type": "module",
    "description": "A dynamic tiling layout manager made for React",
    "main": "lib/react-layman.js",
    "types": "lib/index.d.ts",
    "files": [
        "lib"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "scripts": {
        "dev": "vite",
        "build:demo": "tsc && vite build",
        "preview": "vite preview",
        "build:lib": "tsc --project tsconfig-build.json && vite build --config vite.lib.config.ts",
        "clean": "rm -rf lib/",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublishOnly": "npm run build:lib"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Jeshwin/react-layman.git"
    },
    "keywords": [
        "ui",
        "react",
        "typescript",
        "component",
        "react-layman",
        "window-manager",
        "tiling-window-manager"
    ],
    "author": "Jeshwin Prince",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/Jeshwin/react-layman/issues"
    },
    "homepage": "https://github.com/Jeshwin/react-layman#readme",
    "dependencies": {
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1"
    },
    "devDependencies": {
        "@types/node": "^25.2.3",
        "@types/react": "^18.2.66",
        "@types/react-dom": "^18.2.22",
        "@typescript-eslint/eslint-plugin": "^7.2.0",
        "@typescript-eslint/parser": "^7.2.0",
        "@vitejs/plugin-react-swc": "^4.3.1",
        "eslint": "^8.57.0",
        "eslint-plugin-react": "^7.34.1",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.6",
        "jsdom": "^29.1.1",
        "react": "^18",
        "react-dom": "^18",
        "typescript": "^5.7.2",
        "vite": "^8.0.16",
        "vite-plugin-dts": "^4.3.0",
        "vite-plugin-lib-inject-css": "^2.1.1",
        "vitest": "^4.1.8"
    },
    "peerDependencies": {
        "react": "^18",
        "react-dom": "^18"
    }
}
